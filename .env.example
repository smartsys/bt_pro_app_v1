# Diese Datei nach `.env` kopieren

APP_VERSION=1.30.94

# === Pflicht: vor der Installation eintragen ===

# SSH-Key fuer den VBT-Pro-Pull beim Image-Build. Eigene VBT-Pro-Lizenz noetig
# (Zugriff auf das private Repo polakowo/vectorbt.pro). install.bat/install.sh
# uebergeben diesen Pfad an den Build.
#   Windows (Docker Desktop): liegt der Key in der WSL, per UNC-Pfad angeben:
#     \\wsl.localhost\<Distro>\home\<user>\.ssh\<keyname>
#   Linux/macOS: normaler Pfad, z.B. /home/<user>/.ssh/<keyname>
VBT_SSH_KEY=

# Mit diesen Einstellungen läuft das System direkt.
# Du kannst sie natürlich an deine individuellen Bedürfnisse anpassen.

# PostgreSQL + TimescaleDB (nur lokal, Host-Port 5560)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5560
POSTGRES_DB=vbt
POSTGRES_USER=vbt
POSTGRES_PASSWORD=vbt

# pgAdmin (http://localhost:5563)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin


# === Optional: nur für Zusatzfunktionen, kann leer bleiben ===

# Knowledge-Base
# Hier mache ich die ersten Experimente der Dokumentation der Strategien in Obsidian.
# Ziel ist es, die Erfahrungen aus den einzelnen Iterationen zu speichern und für nächste Strategien oder Ideen zugänglich zu machen.
# Ehrlich gesagt klappt das bis jetzt aber eher mäßig.
# Default zeigt auf einen leeren Dummy-Ordner, damit der Mount nicht abbricht.
# Für das Feature: absoluten Pfad zu deinem echten Obsidian-Vault-Ordner eintragen
# (z.B. D:\MeinVault). Die Obsidian-Deeplinks der App bauen daraus obsidian://open?path=<absoluter Pfad>;
# Obsidian ermittelt den Vault selbst aus dem Pfad — ein separater Vault-Name ist nicht noetig.
OBSIDIAN_VAULT_HOST_PATH=./data/obsidian

# Hier kannst du auch eine Embedding-URL eintragen. Annahme, 50 Strategien, 1000 Iterationen ist für den Kontext der KI etwas viel.
# Daher der Versuch, die über Embeddings zur Verfügung zu stellen.
# Embedding-Backend (bge-m3) für den Vault-Indexer — nur mit Vault nötig:
EMBEDDING_BACKEND_URL=

# OHLC-Download
# Das Projekt hat parallel arbeitende Worker, daher kannst du hier Pausenzeiten für die Binance API einstellen.
# Default: 1000 Datenpunkte, 1.5 Sekunde Pause -  Passt bei drei parallelen Worker
OHLC_FETCH_DELAY=1.5
OHLC_FETCH_LIMIT=1000


# Test-DB für pytest (eigener Port 5562) — nur für die Entwicklung:
#VBT_TEST_DATABASE_URL=postgresql+psycopg2://vbt:vbt@localhost:5562/vbt
